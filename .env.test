# 测试环境配置 - 完全独立于开发/生产环境
# 使用方法: cp .env.test .env 或在运行测试时加载

# =============================================================================
# 数据库配置 - 使用独立的测试数据库
# =============================================================================
# 选项 1: 本地 PostgreSQL 测试数据库
TEST_DATABASE_URL=postgresql+asyncpg://test_user:test_pass@localhost:5432/dragonai_test

# 选项 2: 如果本地没有 PostgreSQL，可以使用 SQLite（不推荐用于集成测试）
# TEST_DATABASE_URL=sqlite+aiosqlite:///./test.db

# =============================================================================
# Redis 配置 - 使用 DB 15 避免与开发/生产冲突
# =============================================================================
TEST_REDIS_URL=redis://localhost:6379/15

# Redis Key 前缀 - 所有测试数据都会加上此前缀，方便清理
TEST_REDIS_KEY_PREFIX=dragonai:test

# =============================================================================
# 应用配置
# =============================================================================
APP_NAME=DragonAI-Test
APP_ENV=testing
APP_DEBUG=true
APP_HOST=127.0.0.1
APP_PORT=8001

# 安全配置 - 使用测试专用的密钥
SECRET_KEY=test-secret-key-for-testing-only-do-not-use-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# =============================================================================
# 限流配置 - 测试环境放宽限制
# =============================================================================
RATE_LIMIT_STORAGE=memory
RATE_LIMIT_DEFAULT=1000/minute
RATE_LIMIT_AUTH=1000/minute
RATE_LIMIT_CHAT=1000/minute

# =============================================================================
# 存储配置 - 使用临时目录
# =============================================================================
# 测试文件存储目录（会自动创建和清理）
TEST_STORAGE_DIR=./storage/test

# =============================================================================
# 外部服务配置 - 测试环境使用 Mock
# =============================================================================
# LLM API - 测试时使用 Mock
MOCK_LLM_API=true

# 禁用外部服务调用
DISABLE_EXTERNAL_SERVICES=true

# =============================================================================
# 日志配置
# =============================================================================
LOG_LEVEL=DEBUG
LOG_FORMAT=simple
